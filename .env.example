# Copy this file to .env and fill in real values.
# .env is git-ignored — never commit actual credentials.

DATABASE_URL="postgresql://postgres:postgrespassword@localhost:5432/codity_jobs?schema=public"

# Generate a strong random value for real deployments, e.g.:
#   openssl rand -base64 48
JWT_SECRET="replace-with-a-long-random-secret"

PORT=5000
NODE_ENV=development
WORKER_CONCURRENCY=5
